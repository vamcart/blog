COMPOSE_PROJECT_NAME=blog

HOST_MACHINE_UNSECURE_HOST_PORT=8090
HOST_MACHINE_MYSQL_PORT = 3310
HOST_MACHINE_PHPMYADMIN_PORT=8091

# MySQL root user password
MYSQL_ROOT_PASSWORD=rootpass

MYSQL_USER=docker
MYSQL_PASSWORD=docker
MYSQL_DATABASE=docker

MYSQL_INITDB_DIR=./.docker-data/config/initdb
MYSQL_CONF_DIR=./.docker-data/config/mysql
MYSQL_DATA_DIR=./.docker-data/data/mysql
MYSQL_LOG_DIR=./.docker-data/logs/mysql
